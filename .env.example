# ─────────────────────────────────────────────────────────────
# H1B Visa Slot Monitor — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git (it's in .gitignore)
# ─────────────────────────────────────────────────────────────

# ── Telegram Bot (for sending alerts TO yourself) ────────────
# 1. Open Telegram, search @BotFather
# 2. Send /newbot, follow prompts → gives you the token below
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your personal Telegram chat ID (the bot will message YOU)
# Get it by messaging @userinfobot on Telegram
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Telegram User Account (for READING public channels) ──────
# 1. Go to https://my.telegram.org
# 2. Log in → "API development tools" → Create app
# 3. Copy App api_id and App api_hash below
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# Session string — run gen_session.py once to generate this
TELEGRAM_SESSION_STR=your_session_string_here
